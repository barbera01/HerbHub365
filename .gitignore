# Terraform
# ====================

# Terraform state files
*.tfstate
*.tfstate.*
*.lock.hcl

# Crash log files
crash.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform variables files (optional)
*.auto.tfvars
*.auto.tfvars.json
*.tfvars
# Terraform plan files
*.tfplan

# Terraform directories
.terraform/
terraform.tfstate.d/

