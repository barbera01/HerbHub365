FROM golang:1.23-alpine AS builder

WORKDIR /src

ARG TARGETOS=linux
ARG TARGETARCH

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -o /out/blog-poster ./cmd/blog-poster

FROM alpine:3.20

WORKDIR /app
RUN apk add --no-cache ca-certificates git
COPY --from=builder /out/blog-poster /usr/local/bin/blog-poster

ENTRYPOINT ["/usr/local/bin/blog-poster"]
