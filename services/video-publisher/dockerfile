FROM golang:1.23-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /out/video-publisher .

FROM alpine:3.20

WORKDIR /app

RUN apk add --no-cache ca-certificates git

COPY --from=builder /out/video-publisher /usr/local/bin/video-publisher

ENTRYPOINT ["/usr/local/bin/video-publisher"]
