# Environment variables for HerbHub365 watering consumer script
# Copy this file to /opt/herbhub/scripts/.env and customize values

# RabbitMQ Configuration
RABBITMQ_HOST=hh-02
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=yourpassword

# Script Configuration  
LOG_FILE=/var/log/herbhub_watering.log
RELAY_SCRIPT_PATH=/opt/herbhub/scripts/relaywrapper.py